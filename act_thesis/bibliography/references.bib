  author = {Gomez, Luis F. and Ferguson, Ken R. and Cryan, James P. and Bacellar, Camila and Tanyag, Rico Mayro P. and Jones, Curtis and Schorb, Sebastian and Anielski, Denis and Belkacem, Ali and Bernando, Charles and Boll, Rebecca and Bozek, John and Carron, Sebastian and Chen, Gang and Delmas, Tjark and Englert, Lars and Epp, Sascha W. and Erk, Benjamin and Foucar, Lutz and Hartmann, Robert and Hexemer, Alexander and Huth, Martin and Kwok, Justin and Leone, Stephen R. and Ma, Jonathan H. S. and Maia, Filipe R. N. C. and Malmerberg, Erik and Marchesini, Stefano and Neumark, Daniel M. and Poon, Billy and Prell, James and Rolles, Daniel and Rudek, Benedikt and Rudenko, Artem and Seifrid, Martin and Siefermann, Katrin R. and Sturm, Felix P. and Swiggers, Michele and Ullrich, Joachim and Weise, Fabian and Zwart, Petrus and Bostedt, Christoph and Gessner, Oliver and Vilesov, Andrey F.},
  date = {2014-08-22},
  journaltitle = {Science},
  volume = {345},
  number = {6199},
  pages = {906--909},
  publisher = {American Association for the Advancement of Science},
  doi = {10.1126/science.1252395},
  url = {https://www.science.org/doi/10.1126/science.1252395},
  urldate = {2026-07-15},
  abstract = {Helium nanodroplets are considered ideal model systems to explore quantum hydrodynamics in self-contained, isolated superfluids. However, exploring the dynamic properties of individual droplets is experimentally challenging. In this work, we used single-shot femtosecond x-ray coherent diffractive imaging to investigate the rotation of single, isolated superfluid helium-4 droplets containing \textasciitilde 108 to 1011 atoms. The formation of quantum vortex lattices inside the droplets is confirmed by observing characteristic Bragg patterns from xenon clusters trapped in the vortex cores. The vortex densities are up to five orders of magnitude larger than those observed in bulk liquid helium. The droplets exhibit large centrifugal deformations but retain axially symmetric shapes at angular velocities well beyond the stability range of viscous classical droplets.},
  file = {/home/soeren/Zotero/storage/3WMFMDZY/Gomez et al. - 2014 - Shapes and vorticities of superfluid helium nanodroplets.pdf;/home/soeren/Zotero/storage/46CFAGK4/science.1252395.pdf}
}

