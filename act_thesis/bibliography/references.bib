@article{varoquauxAndersonsConsiderationsFlow2015,
  title = {Anderson's Considerations on the Flow of Superfluid Helium: {{Some}} Offshoots},
  shorttitle = {Anderson's Considerations on the Flow of Superfluid Helium},
  author = {Varoquaux, Eric},
  date = {2015-08-17},
