@article{allumBreakdownSuperfluidityLiquid1977,
  title = {The Breakdown of Superfluidity in Liquid {{4He}}: An Experimental Test of {{Landau}}’s Theory},
  shorttitle = {The Breakdown of Superfluidity in Liquid {{4He}}},
  author = {Allum, D. R. and McClintock, P. V. E. and Phillips, A. and Bowley, R. M.},
  date = {1977-01-04},
  journaltitle = {Philosophical Transactions of the Royal Society of London, Series A: Mathematical and Physical Sciences},
  shortjournal = {Philos. Trans. R. Soc. Lond. Ser. Math. Phys. Sci.},
  volume = {284},
  number = {1320},
  pages = {179--224},
  issn = {0080-4614},
  doi = {10.1098/rsta.1977.0008},
  url = {https://doi.org/10.1098/rsta.1977.0008},
  urldate = {2026-07-11},
  abstract = {A single pulse time of flight technique has been used to determine the drift velocity F of the negative ions injected into liquid 4He from a field emission source. Measurements of v as a function of temperature T, pressure P and electric field E are presented within the range: 0.29 ≤ T ≤ 0.5 K; 21 x 105 ≤ P ≤ 25 x 105 Pa; 1 ≤ E  ≤ 300kV m-1. The experimental results are in good agreement with Landau’s theory of superfluidity. The data are used to demonstrate the inapplicability of two theories of supercritical dissipation: by Takken, based on an assumption of coherent roton emission; and by Bowley \&amp; Sheard, based on the assumption of incoherent single-roton emission. The results are, however, shown to be in excellent agreement with Bowley \&amp; Sheard’s incoherent two-roton theory, and the data are used to derive a numerical value of the matrix element characterizing two-roton emission. The surprising absence of the single-roton emission process is discussed, and an upper bound is placed on the relevant matrix element.},
  file = {/home/soeren/Zotero/storage/3F9SC53R/Allum et al. - 1977 - The breakdown of superfluidity in liquid 4He an experimental test of Landau’s theory.pdf;/home/soeren/Zotero/storage/L9PXDPTD/rsta.1977.0008.pdf;/home/soeren/Zotero/storage/NE6XUWVC/rsta.1977.html}
}

@article{beckerStrahlenAusKondensiertem1962,
